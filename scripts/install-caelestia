echo "Installing paru..."
sudo pacman -S --needed git base-devel --noconfirm
git clone https://aur.archlinux.org/paru.git
cd paru
makepkg -si --noconfirm
cd ..
rm -rf paru

echo 'Installing metapackage...'
paru -Ui . --noconfirm
rm -f *.pkg.tar.zst

echo 'Installing hypr config...'
git clone --depth=1 --filter=blob:none --sparse https://github.com/caelestia-dots/caelestia.git tmp
cd tmp
git sparse-checkout set hypr
rm -rf ../config/hypr
mv hypr ../config
cd ..
rm -rf tmp
chmod u+x $HOME/dotfiles/config/hypr/scripts/wsaction.fish
hyprctl reload

# Scheme initialization
if ! test -f $HOME/.local/state/caelestia/scheme.json
    caelestia scheme set -n shadotheme
    sleep .5
    hyprctl reload
end

# Start shell
caelestia shell -d >/dev/null

echo 'Done!'
