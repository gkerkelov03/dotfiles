#!/bin/bash

# Get the absolute path of the repository
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOME_DIR="$REPO_ROOT/home"
CONFIG_DIR="$REPO_ROOT/config"
TARGET_HOME="$HOME"
TARGET_CONFIG="$HOME/.config"

# Ensure hidden files (dotfiles) are caught by the loops
shopt -s dotglob

link_files() {
    echo "--- 🔗 Linking Dotfiles ---"
    mkdir -p "$TARGET_CONFIG"

    # 1. Link items from home/ directly to $HOME/
    for item in "$HOME_DIR"/*; do
        [ -e "$item" ] || continue
        target="$TARGET_HOME/$(basename "$item")"

        if [ -e "$target" ] && [ ! -L "$target" ]; then
            echo "⚠️  Skipping $target (Physical file/folder exists)"
        else
            echo "Linking $item -> $target"
            ln -snf "$item" "$target"
        fi
    done

    # 2. Link items from config/ to ~/.config/
    for item in "$CONFIG_DIR"/*; do
        [ -e "$item" ] || continue
        target="$TARGET_CONFIG/$(basename "$item")"

        if [ -e "$target" ] && [ ! -L "$target" ]; then
            echo "⚠️  Skipping $target (Physical file/folder exists)"
        else
            echo "Linking $item -> $target"
            ln -snf "$item" "$target"
        fi
    done
    echo "Done!"
}

remove_links() {
    echo "--- 🗑️ Removing Symlinks ---"

    # Remove links in $HOME
    for item in "$HOME_DIR"/*; do
        target="$TARGET_HOME/$(basename "$item")"
        [ -L "$target" ] && echo "Removing $target" && rm "$target"
    done

    # Remove links in ~/.config
    for item in "$CONFIG_DIR"/*; do
        target="$TARGET_CONFIG/$(basename "$item")"
        [ -L "$target" ] && echo "Removing $target" && rm "$target"
    done
    echo "Done!"
}

show_help() {
    echo "Usage: ./dflinker [option]"
    echo "Options:"
    echo "  -l, --link    Symlink files from repo to system"
    echo "  -r, --remove  Remove symlinks from system"
    echo "  -h, --help    Show this help message"
}

case "$1" in
-l | --link) link_files ;;
-r | --remove) remove_links ;;
*) show_help ;;
esac
