# Set the mod key to the windows key
set $mod Mod4

focus_follows_mouse no
hide_edge_borders smart

# Font for window titles and the i3-bar. 
# the font size is 0 so we don't have a titlebar
font pango: JetBrainsMono Nerd Font 0

# Gaps between windows
gaps inner 30
gaps top 32 
# smart_gaps on

# Start XDG autostart .desktop files using dex. 
exec --no-startup-id dex --autostart --environment i3

#Start picom compositor
exec_always --no-startup-id picom --experimental-backends --config ~/.config/picom/picom.conf 


#Start polybar
exec_always --no-startup-id ~/.config/polybar/launch.sh

# Use pactl to adjust volume in PulseAudio.
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% 

# start a terminal
bindsym $mod+Return exec kitty

# make the title of the windows centered
title_align center

# kill focused window
bindsym $mod+X kill

# start applications launcher
bindsym $mod+d exec --no-startup-id rofi -show drun

# start power menu 
bindsym $mod+q exec --no-startup-id rofi -show powermenu -modi powermenu:~/.config/rofi/scripts/power-menu.sh -debug

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# split in horizontal orientation
#bindsym $mod+h split h

# split in vertical orientation
#bindsym $mod+v split v

# change container layout 
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+f fullscreen toggle

# If some pop up window is displayed while in full screen just leave fullscreen to make sure we notice the pop up window, might be important.
popup_during_fullscreen leave_fullscreen

# Define names for the workspaces using variables
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5

# if you open workspace 2 from workspace 1 go back to workspace 1 with the same shortcut that you opened workspace 2 with.
workspace_auto_back_and_forth yes

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5

# reload the configuration file
bindsym $mod+Shift+c reload
# restart i3 inplace 
bindsym $mod+Shift+r restart
# exit i3 
bindsym $mod+Shift+e exit

# resize windows 
bindsym $mod+r mode "resize"
mode "resize" {
    bindsym h resize grow width 10 px or 10 ppt
    bindsym j resize grow height 10 px or 10 ppt
    bindsym k resize shrink height 10 px or 10 ppt
    bindsym l resize shrink width  10 px or 10 ppt

    # back to normal: Enter 
    bindsym Return mode "default"
}

#disable the floating for jetbrains toolbox cuz it was floating by default
for_window [title="JetBrains Toolbox"] floating disable 

for_window [class="Vivaldi-stable"] border normal
for_window [class="Code"] border normal


exec_always --no-startup-id feh --bg-scale ~/Documents/g-comp/wallpapers/purple-trees.jpg


