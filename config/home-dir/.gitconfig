[user]
    name = Georgi Kerkelov
    email = gkerkelov03@gmail.com

[core]
    editor = nvim
    pager = delta
    # Speed up git on large repos by caching file system stats
    fsmonitor = true
    untrackedCache = true

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true    # use n and p to jump between files
    side-by-side = true
    line-numbers = true
    features = decorations
    # Using 16-color names for terminal compatibility
    minus-style = red italic
    plus-style = green bold
    syntax-theme = none

[delta "decorations"]
    commit-decoration-style = bold yellow box ul
    file-style = bold yellow ul
    file-decoration-style = blue box
    line-numbers-left-style = cyan
    line-numbers-right-style = cyan

[diff]
    # Better diff algorithm for moved code blocks
    colorMoved = default
    # Use the 'histogram' algorithm for more readable diffs
    algorithm = histogram
    # Renames are detected more accurately
    renames = true

[merge]
    conflictstyle = zdiff3
    # Automatically setup a backup during merge
    keepBackup = false

[push]
    # Automatically setup remote tracking on first push
    autoSetupRemote = true
    # Only push the current branch
    default = current
    followTags = true

[pull]
    # Keeps history linear and clean
    rebase = true

[rebase]
    # Automatically stash changes before rebasing
    autoStash = true
    # Shows a summary of what changed in the rebase
    stat = true

[column]
    ui = auto

[branch]
    sort = -committerdate

[fetch]
    prune = true
    all = true

[init]
    defaultBranch = main

[help]
    # Autocorrect typos in git commands (e.g. 'git stats' -> 'git status')
    autocorrect = prompt
