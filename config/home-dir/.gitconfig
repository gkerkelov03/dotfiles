[user]
    name = Georgi Kerkelov
    email = gkerkelov03@gmail.com

[core]
    editor = nvim
    pager = delta
    # Speed up git on large repos by caching file system stats
    fsmonitor = true
    untrackedCache = true

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true    
    side-by-side = true
    line-numbers = true

[diff]
    colorMoved = default
    algorithm = histogram
    renames = true

[merge]
    conflictstyle = zdiff3
    # Automatically setup a backup during merge
    keepBackup = false

[push]
    # Automatically setup remote tracking on first push
    autoSetupRemote = true
    # Only push the current branch
    default = current
    followTags = true

[pull]
    # Keeps history linear and clean
    rebase = true

[rebase]
    # Automatically stash changes before rebasing
    autoStash = true
    # Shows a summary of what changed in the rebase
    stat = true

[column]
    ui = auto

[branch]
    sort = -committerdate

[fetch]
    prune = true
    all = true

[init]
    defaultBranch = main

[help]
    # Autocorrect typos in git commands (e.g. 'git stats' -> 'git status')
    autocorrect = prompt
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
